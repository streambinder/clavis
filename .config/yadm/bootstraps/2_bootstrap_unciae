#!/bin/bash

set -euo pipefail

cd "${HOME}"

# strip caller venv: loop spans many projects, each with own .venv
unset VIRTUAL_ENV

echo "Syncing unciae submodule..."
yadm submodule update --init --recursive .local/share/unciae

echo "Deleting broken symlinks..."
find -L .local/bin -maxdepth 1 -type l -print -exec rm -f {} +

echo "Linking existing tools..."
find .local/share/unciae -type f -name "runner.*" -not -path '*/.venv/*' | while read -r fname; do
	# file name: .local/share/unciae/category/uncia/runner.sh
	fname_bin="$(awk -F/ '{print $(NF-1)}' <<<"${fname}")" # script name: uncia
	fname_bin_rel="${fname/.local/..}"                     # path relative to .local/bin: ../share/unciae/category/uncia/runner.sh
	fname_bin_path=".local/bin/${fname_bin}"               # script target path: .local/bin/uncia
	fname_bin_parent="$(dirname "${fname}")"               # script directory: .local/share/unciae/category/uncia
	fname_abs="$(realpath "${fname}")"                     # absolute path to the script: /home/$USER/.local/share/unciae/category/uncia/runner.sh
	rm -f "${fname_bin_path}"
	case "${fname##*.}" in
	sh)
		echo "Linking shell script ${fname_bin} at ${fname_bin_path}"
		ln -sf "${fname_bin_rel}" "${fname_bin_path}"
		;;
	py)
		fname_pyproject="${fname_bin_parent}/pyproject.toml"
		if [ ! -f "${fname_pyproject}" ]; then
			echo "ERROR: ${fname_bin} missing pyproject.toml at ${fname_bin_parent} (per unciae/ai/README.md §21.10)" >&2
			exit 1
		fi
		fname_parent_abs="$(realpath "${fname_bin_parent}")"
		echo "Provisioning Python script ${fname_bin} via uv at ${fname_bin_path}"
		uv sync --frozen --project "${fname_parent_abs}"
		cat >"${fname_bin_path}" <<-EOF
			#!/bin/bash
			exec env -u VIRTUAL_ENV uv --project "${fname_parent_abs}" run --frozen python "${fname_abs}" "\$@"
		EOF
		chmod a+x "${fname_bin_path}"
		# pre-compile bytecode for faster cold-start
		uv --project "${fname_parent_abs}" run --frozen python -m compileall -q "${fname_parent_abs}" >/dev/null 2>&1 || echo "${fname_bin} compileall failed"
		;;
	go)
		echo "Building Go script ${fname_bin} at ${fname_bin_path}"
		cd "${fname_bin_parent}"
		go build
		cd - >/dev/null
		mv "${fname_bin_parent}/${fname_bin}" "${fname_bin_path}"
		;;
	esac
	[ -e "${fname_bin_path}" ] && chmod a+x "${fname_bin_path}"
done
