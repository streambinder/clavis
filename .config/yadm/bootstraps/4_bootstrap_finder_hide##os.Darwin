#!/bin/bash

set -euo pipefail

# macOS Finder ignores .hidden; use chflags hidden flag instead.
# Read entries from ~/.hidden (Nautilus convention), apply chflags to each.
while IFS= read -r entry || [ -n "${entry}" ]; do
	[ -z "${entry}" ] && continue
	case "${entry}" in \#*) continue ;; esac
	path="${HOME}/${entry}"
	[ -e "${path}" ] || continue
	echo "Hiding ${path}"
	chflags hidden "${path}"
done <"${HOME}/.hidden"
